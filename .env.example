# ─────────────────────────────────────────────
#  JLPT N5 Study Hub — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000

# ── Twilio SMS Credentials ──
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Your Registered Mobile Number (receives SMS reminders) ──
# Format: +91XXXXXXXXXX  (India)  or  +1XXXXXXXXXX  (US)
YOUR_PHONE_NUMBER=+91XXXXXXXXXX

# ── App Secret (any random string, used for API security) ──
APP_SECRET=change_this_to_a_random_secret_string
